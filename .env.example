# Copy to .env and fill in. .env is gitignored.

# OpenAI: any key with gpt-4.1 access.
OPENAI_API_KEY=sk-...

# Slack: from your Slack app's Install / Basic Information pages.
# Bot token starts with xoxb-. App-level token (connections:write) starts with xapp-.
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Optional: comma- or space-separated Slack user IDs (U...) allowed to use the bot.
# Empty/unset allows all users.
SLACK_ALLOWED_USERS=
